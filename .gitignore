*.swp
*.swo

# Environment
.env
.env.local

# Local-only working notes
.cowork/

# pnpm
pnpm-debug.log*

# Coverage
coverage/

# Deslint scan artifacts
.deslint/

# Smoke-test screenshots (regenerated on demand)
apps/docs/scripts/.smoke-out/
