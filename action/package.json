{
  "name": "@deslint/action",
  "version": "0.1.1",
  "private": true,
  "description": "GitHub Action for Deslint PR design reviews",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@deslint/eslint-plugin": "workspace:*",
    "@deslint/shared": "workspace:*",
    "eslint": "^9.27.0",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
