{
  "name": "@vizlint/mcp",
  "version": "0.1.1",
  "description": "MCP server for Vizlint — real-time design quality feedback in Cursor/Claude Code",
  "license": "MIT",
  "author": "Vizlint",
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "@vizlint/mcp": "./dist/cli.js",
    "vizlint-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vizlint/cli": "workspace:^",
    "@vizlint/eslint-plugin": "workspace:^",
    "@vizlint/shared": "workspace:*",
    "eslint": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
