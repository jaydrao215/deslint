{
  "name": "@deslint/mcp",
  "version": "0.3.0",
  "description": "MCP server for Deslint — real-time design quality feedback in Cursor/Claude Code",
  "homepage": "https://deslint.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaydrao215/deslint.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/jaydrao215/deslint/issues"
  },
  "license": "MIT",
  "author": "Deslint",
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "@deslint/mcp": "./dist/cli.js",
    "deslint-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@deslint/cli": "workspace:^",
    "@deslint/eslint-plugin": "workspace:^",
    "@deslint/shared": "workspace:*",
    "eslint": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
