{
  "name": "eslint-plugin-vizlint",
  "version": "0.1.0",
  "description": "The design quality gate for AI-generated frontend code",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "design",
    "tailwind",
    "ui",
    "quality",
    "lint",
    "design-system",
    "ai"
  ],
  "license": "MIT",
  "author": "Vizlint",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "bench": "node --import tsx bench/rules.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@angular-eslint/template-parser": ">=18.0.0",
    "eslint": ">=10.0.0",
    "vue-eslint-parser": ">=9.0.0",
    "svelte-eslint-parser": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "@angular-eslint/template-parser": {
      "optional": true
    },
    "vue-eslint-parser": {
      "optional": true
    },
    "svelte-eslint-parser": {
      "optional": true
    }
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "eslint": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
