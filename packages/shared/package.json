{
  "name": "@vizlint/shared",
  "version": "0.1.0",
  "description": "Shared types, schemas, and utilities for Vizlint",
  "license": "MIT",
  "author": "Vizlint",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
