{
  "name": "@deslint/shared",
  "version": "0.6.0",
  "description": "Shared types, schemas, and utilities for Deslint",
  "homepage": "https://deslint.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaydrao215/deslint.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/jaydrao215/deslint/issues"
  },
  "license": "MIT",
  "author": "Deslint",
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
