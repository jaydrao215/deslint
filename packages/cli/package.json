{
  "name": "@deslint/cli",
  "version": "0.6.0",
  "description": "CLI for Deslint — project-wide design quality analysis + Design Health Score",
  "homepage": "https://deslint.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaydrao215/deslint.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/jaydrao215/deslint/issues"
  },
  "license": "MIT",
  "author": "Deslint",
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "bin": {
    "deslint": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@deslint/eslint-plugin": "workspace:^",
    "@deslint/shared": "workspace:*",
    "@typescript-eslint/parser": "^8.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "eslint": "^10.0.0",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@html-eslint/parser": "^0.59.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vue-eslint-parser": "^10.4.0"
  }
}
